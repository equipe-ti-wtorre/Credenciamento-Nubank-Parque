{
  "name": "credenciamento-frontend",
  "version": "0.0.0",
  "scripts": {
    "start": "bash -c 'fuser -k 4207/tcp 2>/dev/null || true; sleep 1; exec env PATH=/www/server/nodejs/v24.11.1/bin:$PATH node ./node_modules/@angular/cli/bin/ng.js serve --port 4207 --host 127.0.0.1 --proxy-config proxy.conf.json'",
    "build": "PATH=/www/server/nodejs/v24.11.1/bin:$PATH ng build --configuration development",
    "build:prod": "PATH=/www/server/nodejs/v24.11.1/bin:$PATH ng build --configuration production",
    "build:mobile": "ng build --configuration mobile && npx cap sync",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "ng": "ng"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.3",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@azure/msal-angular": "^5.0.3",
    "@azure/msal-browser": "^5.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^8.3.4",
    "@capacitor/preferences": "^8.0.1",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.18",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}
