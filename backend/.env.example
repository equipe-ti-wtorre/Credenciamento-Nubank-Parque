PORT=3007
NODE_ENV=development
API_VERSION=v1

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=credenciamento
DB_POOL_LIMIT=10
DB_CONNECT_TIMEOUT_MS=30000

JWT_SECRET=altere_esta_chave_em_producao_min_32_chars
REFRESH_TOKEN_SECRET=altere_refresh_secret_em_producao_min_32
JWT_ACCESS_EXPIRES=30m
JWT_REFRESH_EXPIRES=7d
ENCRYPTION_KEY=gerar_com_openssl_rand_hex_32

CORS_ORIGINS=http://localhost:4207,http://127.0.0.1:4207
LOG_LEVEL=info

# Rate limit (429). Reinicie a API após alterar. Login tem limite próprio por IP.
# RATE_LIMIT_DISABLED=true
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_GLOBAL_MAX=300

ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=admin123

ORGANIZATION_NAME=Nome da Organização

MSAL_REDIRECT_URI_WEB=
# URL https ao clicar na notificação Teams (obrigatório https; ex.: https://credenciamento.suaempresa.com)
TEAMS_ACTIVITY_WEB_URL=
# ID do app no catálogo Graph após publicar teams-app/ (veja teams-app/README.md)
# Ex.: 7ba5b35a-67b1-4877-b65f-f0e17c373c2f (catálogo Graph — node teams-app/query-teams-app-id.mjs)
TEAMS_APP_ID=
# GUID do campo "id" no manifest.json (padrão do repositório se não alterar o manifest)
TEAMS_APP_EXTERNAL_ID=c8f4a2b1-6d3e-4f5a-9b0c-1e2d3f4a5b6c
# Bot Framework — opcional. Se vazio, usa o tenant principal de Configurações → Tenants Azure
# (client_id + secret + azure_tenant_id). Override apenas se precisar de um app/bot separado:
# TEAMS_BOT_APP_ID=90ac8301-8401-4287-9e69-287a4cdcbc2b
# TEAMS_BOT_APP_PASSWORD=
# TEAMS_BOT_TENANT_ID=
# TEAMS_BOT_SERVICE_URL=https://smba.trafficmanager.net/amer/
MSAL_REDIRECT_URI_ANDROID=
MSAL_REDIRECT_URI_IOS=

# Sync automática de usuários do Azure AD (cron interna ao iniciar a API)
AD_USERS_SYNC_ENABLED=true
# Padrão: todo dia às 02:00 (timezone abaixo)
AD_USERS_SYNC_CRON=0 2 * * *
AD_USERS_SYNC_TIMEZONE=America/Sao_Paulo

# Arquivamento de audit_logs (cold storage JSONL.gz; cron interna às 03:00)
AUDIT_RETENTION_ENABLED=true
AUDIT_RETENTION_CRON=0 3 * * *
AUDIT_RETENTION_TIMEZONE=America/Sao_Paulo
# LIST/READ: retenção menor (alto volume)
AUDIT_RETENTION_READ_DAYS=90
# Demais ações (login, PATCH, SYNC, etc.)
AUDIT_RETENTION_DEFAULT_DAYS=365
AUDIT_ARCHIVE_DIR=./storage/audit-archive
AUDIT_ARCHIVE_BATCH_SIZE=2000
AUDIT_ARCHIVE_MAX_BATCHES=50
# true = exporta sem apagar da tabela (homologação)
AUDIT_ARCHIVE_DRY_RUN=false

# Portaria: tolerância em horas além do dia do evento (equipes de montagem/desmontagem)
GATE_ACCESS_TOLERANCE_HOURS=6

# --- Validador facial (a calibrar com fotos reais do balcão) ---
# FACES_CENTER_MAX_OFFSET_RATIO=0.15
# FACES_MARGIN_MIN_RATIO=0.05
# FACES_WIDTH_MIN_RATIO=0.25
# FACES_WIDTH_MAX_RATIO=0.75
# FACES_POSE_MAX_YAW_DEG=20
# FACES_POSE_MAX_PITCH_DEG=20
# FACES_POSE_MAX_ROLL_DEG=15
# FACES_POSE_MARGIN_DEG=5
# FACES_POSE_ROLL_SANITY_MAX_DEG=12
# FACES_EAR_MIN=0.22
# FACES_LAPLACIAN_MIN=80
# FACES_LUMA_MIN=60
# FACES_LUMA_MAX=200
# FACES_SAT_HIGH_RATIO_MAX=0.15
# FACES_SAT_LOW_RATIO_MAX=0.15
# FACES_OPENCV_INIT_TIMEOUT_MS=15000
# FACES_DAHUA_MIN_SHORT=150
# FACES_DAHUA_MIN_LONG=300
# FACES_DAHUA_MAX_SHORT=600
# FACES_DAHUA_MAX_LONG=1200
# FACES_DAHUA_MIN_SIDE=500
# FACES_DAHUA_MIN_SIDE_SOFT=360
# FACES_DAHUA_MAX_BYTES=102400
# FACES_CONTROLID_MAX_BYTES=1048576
# FACES_MODELS_PATH=./models/face-api
